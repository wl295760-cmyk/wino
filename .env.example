# ─────────────────────────────────────────────
# 위노뷰티 환경 변수 템플릿 (저장소 커밋 OK, 실제 값 없음)
# 사용법: cp .env.example .env.local 후 값 입력
# ─────────────────────────────────────────────

# ───── Database ─────
# MVP/로컬: SQLite
DATABASE_URL="file:./prisma.db"
# Production (Supabase Seoul 전환 시 주석 해제, schema.prisma provider도 변경):
# DATABASE_URL="postgresql://postgres:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ───── 세션 / 암호화 (32바이트 hex) ─────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
ADMIN_PASSWORD_PEPPER=""

# ───── 이메일 (Resend) ─────
EMAIL_API_KEY=""
EMAIL_FROM="reservations@winobeauty.com"
EMAIL_ADMIN_TO=""

# ───── 카카오맵 (선택) ─────
NEXT_PUBLIC_KAKAO_MAP_API_KEY=""

# ───── 사이트 정보 ─────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_PHONE=""

# ───── 환경 ─────
NODE_ENV="development"
